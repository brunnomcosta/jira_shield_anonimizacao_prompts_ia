{
  "name": "lgpd-export-standalone",
  "version": "1.0.0",
  "description": "Exportação anonimizada de issues do Jira Server conforme LGPD (Lei 13.709/2018)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "export": "node src/index.js",
    "export:jira": "node src/index.js --jira-only",
    "setup": "node src/setup.js",
    "diagnose": "node src/diagnostics.js",
    "test": "node --test",
    "build:extension": "node scripts/build-extension.js",
    "build:icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "jspdf": "^2.5.1",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
