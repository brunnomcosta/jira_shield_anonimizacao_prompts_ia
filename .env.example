# ─────────────────────────────────────────────────────────────
#  Configuração do LGPD Export — Jira Server
#  Copie este arquivo para .env e preencha com seus dados.
#  NUNCA commite o .env em repositórios!
# ─────────────────────────────────────────────────────────────

# URL base do seu Jira Server (sem barra no final)
JIRA_BASE_URL=https://jiraproducao.totvs.com.br

# Autenticação — escolha UMA das opções abaixo:

# Opção A: Token de API pessoal (recomendado para Jira 8.14+)
# Gere em: Jira → Seu perfil → Personal Access Tokens
# Se ficar vazio, diagnostics.js pode perguntar pelo token no início da execução.
JIRA_TOKEN=seu_token_pessoal_aqui

# Opção B: Usuário + senha (fallback para versões antigas)
# Descomente as duas linhas abaixo e comente JIRA_TOKEN
# JIRA_USER=seu.usuario@empresa.com
# JIRA_PASSWORD=sua_senha

# Pasta onde os PDFs serão salvos (padrão: ./output)
OUTPUT_DIR=./output

# ─────────────────────────────────────────────────────────────
#  Zendesk Comments (opcional)
#  Se configurado, os comentários do ticket Zendesk vinculado à
#  issue serão buscados e incluídos no PDF anonimizado.
# ─────────────────────────────────────────────────────────────

# URL base do Zendesk (sem barra no final)
# ZENDESK_BASE_URL=https://suaempresa.zendesk.com

# E-mail do agente + API Token do Zendesk
# Gere o token em: Zendesk Admin → Apps & Integrations → Zendesk API
# ZENDESK_USER=seu.email@empresa.com
# ZENDESK_TOKEN=seu_api_token_zendesk

# Campo do Jira que guarda o(s) ID(s) do ticket Zendesk vinculado
# No Jira TOTVS o campo padrão é customfield_11086 (array de IDs)
# ZENDESK_JIRA_FIELD=customfield_11086

# ─────────────────────────────────────────────────────────────
#  Diagnóstico LGPD (script diagnostics.js)
#  Necessário para análise automática de qualidade de anonimização.
#  Gere sua chave em: https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...

# Ordem de tentativa dos provedores LLM.
# Use para priorizar a sessao/licenca ja ativa no VS Code / Codex CLI.
# Opcoes aceitas: claude, codex, copilot, anthropic
# Exemplo para priorizar o login do Codex CLI:
# LLM_PROVIDER_ORDER=codex,claude,copilot,anthropic

# ─────────────────────────────────────────────────────────────
#  Workspace da aplicação (opcional)
#  Aponte para os diretórios de código-fonte do back-end e/ou
#  front-end da aplicação para diagnóstico cruzado com a issue.
#  O script escaneia automaticamente os arquivos relevantes.
#  Em terminal interativo, diagnostics.js pode perguntar pelos
#  diretórios ausentes e gravá-los no .env e no ambiente do usuário.
# ─────────────────────────────────────────────────────────────

# Diretório raiz do back-end (ex: projeto Java, Node, Python etc.)
# WORKSPACE_ERP_BACKEND_DIR=C:/projetos/meu-erp-backend/src

# Diretório raiz do front-end (ex: projeto React, Angular, Vue etc.)
# WORKSPACE_MOBILE_FRONTEND_DIR=C:/projetos/meu-app-mobile/src
# O diretÃ³rio mobile sÃ³ entra na anÃ¡lise quando o ticket indicar
# app mobile, Minha ProduÃ§Ã£o, celular, tablet ou sinÃ´nimos.

# Diretorio raiz dos includes usados por fontes .prw/.prx/.tlpp
# Ex: arquivos .ch com STR, mensagens de help e textos de UI referenciados via #include
# WORKSPACE_ERP_INCLUDE_DIR=C:/totvs/protheus/includes

# Extensões de arquivo a incluir (padrão: js,ts,java,py,cs,go,kt,jsx,tsx,vue,rb,php,prx,prw,tlpp)
# WORKSPACE_EXTENSIONS=java,ts,tsx,prw,tlpp,prx
